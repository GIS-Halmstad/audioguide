{
  "name": "audioguide",
  "private": true,
  "version": "1.4.0",
  "description": "Audioguide",
  "license": "MIT",
  "author": "Jacob Wodzyński",
  "homepage": "https://github.com/GIS-Halmstad/audioguide#readme",
  "repository": "https://github.com/GIS-Halmstad/audioguide.git",
  "bugs": {
    "url": "https://github.com/GIS-Halmstad/audioguide/issues"
  },
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production vite build",
    "build-capacitor-ios": "cross-env NODE_ENV=production vite build && npx cap copy ios",
    "build-capacitor-android": "cross-env NODE_ENV=production vite build && npx cap copy android",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "postinstall": "cpy --flat ./node_modules/framework7-icons/fonts/*.* ./src/fonts/ && cpy --flat ./node_modules/material-icons/iconfont/*.* ./src/fonts/"
  },
  "browserslist": [
    "IOS >= 15",
    "Safari >= 15",
    "last 5 Chrome versions",
    "last 5 Firefox versions"
  ],
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "dom7": "^4.0.6",
    "flag-icons": "^7.5.0",
    "framework7": "^9.0.3",
    "framework7-icons": "^5.0.5",
    "framework7-react": "^9.0.3",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "material-icons": "^1.13.14",
    "ol": "^10.8.0",
    "plausible-tracker": "^0.3.9",
    "proj4": "^2.20.3",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "skeleton-elements": "^4.0.1",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@types/proj4": "^2.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "cordova-res": "^0.15.4",
    "cpy-cli": "^7.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
